    "n = int(\"Enter number \")\n",
    "\n",
    "def is_power_of_ten(e, n):\n",
    "    if n >= 0:\n",
    "        if pow(10,e) == n:\n",
    "                print(\"power of n is \",e)\n",
    "                return True \n",
    "        else:\n",
    "            return is_power_of_ten(e-1,n)\n",
    "e = 100\n",
    "\n",
    "is_power_of_ten(e,n)"
